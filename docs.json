{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Velobase",
  "theme": "mint",
  "favicon": "https://media.brand.dev/c702550f-bbda-4975-9417-7d54238d0713.png",
  "colors": {
    "primary": "#2D2D2D",
    "light": "#6366f1",
    "dark": "#2D2D2D"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@velobase.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://velobase.io/dashboard"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Velobase Home",
          "icon": "house",
          "href": "https://velobase.io"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/velobaseai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Integration Guides",
            "pages": [
              "integration/mcp",
              "integration/depositing-credits",
              "integration/direct-deduction",
              "integration/staged-deduction"
            ]
          },
          {
            "group": "Dashboard & Management",
            "pages": [
              "dashboard/projects",
              "dashboard/customers-ledger",
              "dashboard/team"
            ]
          },
          {
            "group": "Advanced Topics",
            "pages": [
              "advanced/errors",
              "advanced/idempotency"
            ]
          },
          {
            "group": "Pricing",
            "pages": [
              "pricing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoints"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/velobaseai",
      "x": "https://x.com/velobaseai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"],
    "display": "header"
  }
}
